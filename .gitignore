# Python/runtime cache
__pycache__/
*.py[cod]
.pytest_cache/

# Local model/cache folders. These can be regenerated/downloaded.
.cache/
.matplotlib-cache/
notebooks/.matplotlib-cache/

# Jupyter temporary files
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# OS/editor noise
.DS_Store
*.swp
*.swo

# Local environments and secrets
.env
.venv/
venv/
env/

# Large model weights should not be committed to Git.
*.safetensors
*.bin
*.pt
*.pth
*.onnx

# Qdrant runtime lock file
data/qdrant_db/.lock
